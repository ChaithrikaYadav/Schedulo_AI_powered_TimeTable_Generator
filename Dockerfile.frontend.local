FROM node:20-alpine

WORKDIR /app

# Install dependencies first (layer cache — only rebuilds when package.json changes)
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci --prefer-offline --silent

# Copy source (node_modules stays INSIDE the container — NOT mounted from host)
# This avoids Windows/Linux binary incompatibility issues with native node modules
COPY frontend/ .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
