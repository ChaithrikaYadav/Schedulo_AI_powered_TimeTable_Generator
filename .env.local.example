# ── Deployment Tier ──────────────────────────────────────────
ENVIRONMENT=local
DEBUG=true
SECRET_KEY=local-dev-secret-change-in-production-only

# ── Database ─────────────────────────────────────────────────
DB_ENGINE=sqlite                         # sqlite | postgresql
DATABASE_URL=sqlite+aiosqlite:///./chronoai.db
# Uncomment below for PostgreSQL (requires Docker or local Postgres):
# DATABASE_URL=postgresql+asyncpg://chronoai:localpassword123@localhost:5432/chronoai_local

# ── Cache ─────────────────────────────────────────────────────
CACHE_BACKEND=memory                     # memory | redis
REDIS_URL=redis://localhost:6379/0

# ── Task Queue ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=true            # Run tasks synchronously in prototype

# ── File Storage ──────────────────────────────────────────────
STORAGE_BACKEND=local                    # local | s3 | azure
OUTPUT_DIR=./outputs
MODELS_DIR=./models
LOGS_DIR=./logs

# ── Hugging Face LLM ─────────────────────────────────────────
# Obtain free token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_PRIMARY_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_FALLBACK_MODEL=HuggingFaceH4/zephyr-7b-beta
HF_FAST_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
HF_INFERENCE_URL=https://api-inference.huggingface.co/models
HF_MAX_NEW_TOKENS=1024
HF_TEMPERATURE=0.3
HF_TOP_P=0.9
HF_REPETITION_PENALTY=1.1
HF_STREAM=true

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=local-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440         # 24 hours locally

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Scheduler Performance (tuned for laptop hardware) ─────────
GA_POPULATION_SIZE=50
GA_MAX_GENERATIONS=100
CSP_TIME_LIMIT_SECONDS=30
RL_TRAINING_TIMESTEPS=100000
