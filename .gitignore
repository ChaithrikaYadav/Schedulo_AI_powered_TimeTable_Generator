# =============================================================================
# Schedulo — .gitignore
# This file must be AIRTIGHT. Nothing in this list should ever be committed.
# =============================================================================

# ── Virtual environments (NEVER commit these — they are machine-specific) ────
.venv/
venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# ── Environment variable files (contain secrets) ─────────────────────────────
.env
.env.local
.env.server
.env.cloud
.env.*.local
*.env

# ── Python bytecode (machine-specific, regenerated automatically) ─────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Python test + type checking caches ────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
junit.xml
test-results/
.hypothesis/

# ── Python build artifacts ────────────────────────────────────────────────────
*.egg-info/
dist/
build/
*.egg
*.whl
pip-log.txt
pip-delete-this-directory.txt
MANIFEST

# ── Node / Frontend (npm install will recreate these) ─────────────────────────
node_modules/
frontend/node_modules/
frontend/.pnpm-store/
frontend/dist/
frontend/.env
.npm
.pnp
.pnp.js
.yarn/

# ── Vite build cache ──────────────────────────────────────────────────────────
frontend/.vite/

# ── Databases (SQLite — regenerated by seed_from_csvs.py) ────────────────────
*.db
*.sqlite
*.sqlite3

# ── ML model weight files (too large for git; retrain locally) ───────────────
ml_models/*.pkl
ml_models/*.joblib
ml_models/*.h5
ml_models/*.pt
ml_models/*.onnx
ml_models/*.ckpt

# ── Generated output files (timetable exports) ───────────────────────────────
outputs/
!outputs/.gitkeep

# ── Application logs ─────────────────────────────────────────────────────────
logs/
!logs/.gitkeep
*.log

# ── Docker persistent data volumes ───────────────────────────────────────────
data/postgres/
data/redis/

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.tmp
*.bak
*.swp
*.swo
*~

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Coverage and reports ─────────────────────────────────────────────────────
.coverage.*
nosetests.xml

# ── Celery ───────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Redis dump ───────────────────────────────────────────────────────────────
dump.rdb